
{
  "quizTitle": "לינאריזציות",
  "cards": [
    {
      "q": "מהם הצירים בלינאריזציית Lineweaver-Burk?",
      "a": "$\\frac{1}{v}$ (ציר Y) כנגד $\\frac{1}{[S]}$ (ציר X)."
    },

    {
    "q": "איך מוציאים $V_{max}$ ו-$K_M$ מגרף Lineweaver-Burk?",
    "a": "השיפוע (Slope) הוא: <br> $\\frac{K_M}{V_{max}}$ <br><br> והחיתוך עם ציר $Y$ (Intercept) הוא: <br> $\\frac{1}{V_{max}}$"
    },

    {
      "q": "מהם הצירים בלינאריזציית Eadie-Hofstee?",
      "a": "$v$ (ציר Y) כנגד $\\frac{v}{[S]}$ (ציר X)."
    },

    {
      "q": "מהם הצירים בלינאריזציית Hanes-Woolf?",
      "a": "$\\frac{[S]}{v}$ (ציר Y) כנגד $[S]$ (ציר X)."
    }
]
}