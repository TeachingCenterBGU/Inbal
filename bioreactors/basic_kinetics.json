{
  "quizTitle": "ביוראקטורים ב - קינטיקה אנזימטית: מודלים וקבועים",
  "cards": [
    {
      "q": "מהי משוואת מיכאליס-מנטן למהירות האנזימטית?",
      "a": "$v = \\frac{V_{max} \\cdot [S]}{K_M + [S]}$"
    },
    {
      "q": "מה מייצג $v$ במשוואות הקינטיקה האנזימטית?",
      "a": "קצב התגובה או הפעילות הקטליטית: <br> $\\frac{dP}{dt} = -\\frac{d[S]}{dt}$"
    },
    {
      "q": "מה מייצג $[S]$ במודל מיכאליס-מנטן?",
      "a": "ריכוז הסובסטרט."
    },
    {
      "q": "מה הקשר בין $V_{max}$ לבין ריכוז האנזים?",
      "a": "$V_{max}$ פרופורציוני לריכוז האנזים: <br> $V_{max} = k_{cat} \\cdot [E]_0$"
    },
    {
      "q": "מהו $k_{cat}$?",
      "a": "קבוע הקטליזה (turnover number): מספר מחזורי הקטליזה ליחידת זמן לכל אתר פעיל ברוויה."
    },
    {
      "q": "מהי המשמעות האופרטיבית של $K_M$?",
      "a": "ריכוז הסובסטרט שבו המהירות שווה למחצית המהירות המקסימלית: <br> $v = \\frac{V_{max}}{2}$"
    },
    {
      "q": "מה קורה למשוואה כאשר $[S] \\ll K_M$?",
      "a": "המהירות בקירוב לינארית בריכוז הסובסטרט: <br> $v \\approx \\frac{V_{max}}{K_M} \\cdot [S]$"
    },
    {
      "q": "מה קורה למשוואה כאשר $[S] \\gg K_M$?",
      "a": "האנזים ברוויה והמהירות מתקרבת למקסימום: <br> $v \\approx V_{max}$"
    },

    {
      "q": "מה ההבדל בין פירוש $K_M$ בהנחת MM לעומת BH?",
      "a": "MM (שיווי משקל): $K_M = \\frac{k_{-1}}{k_1}$ <br> BH (מצב עמיד): $K_M = \\frac{k_{-1} + k_2}{k_1}$"
    },

    {
      "q": "מהם הצירים בלינאריזציית Lineweaver-Burk?",
      "a": "$\\frac{1}{v}$ (ציר Y) כנגד $\\frac{1}{[S]}$ (ציר X)."
    },

    {
    "q": "איך מוציאים $V_{max}$ ו-$K_M$ מגרף Lineweaver-Burk?",
    "a": "השיפוע (Slope) הוא: <br> $\\frac{K_M}{V_{max}}$ <br><br> והחיתוך עם ציר $Y$ (Intercept) הוא: <br> $\\frac{1}{V_{max}}$"
    },

    {
      "q": "מהם הצירים בלינאריזציית Eadie-Hofstee?",
      "a": "$v$ (ציר Y) כנגד $\\frac{v}{[S]}$ (ציר X)."
    },

    {
      "q": "מהם הצירים בלינאריזציית Hanes-Woolf?",
      "a": "$\\frac{[S]}{v}$ (ציר Y) כנגד $[S]$ (ציר X)."
    }
  ]
}